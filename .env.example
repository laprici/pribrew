# Copia este archivo a .env.local y rellena con tus credenciales de Supabase.
# Local:  obtén estos valores con `supabase status` (tras `supabase start`).
# Remoto: están en el dashboard del proyecto → Settings → API.

VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_ANON_KEY=

# Resend: API key usada como contraseña SMTP para los correos de Auth
# (config.toml la lee con env(RESEND_API_KEY)). Solo necesaria para enviar
# correos en local o al hacer `supabase config push`.
RESEND_API_KEY=
